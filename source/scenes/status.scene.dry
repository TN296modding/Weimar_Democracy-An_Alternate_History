@polls
on-arrival: {!
Q.pro_republic_disp = Math.floor(Q.pro_republic);
Q.nationalism_disp = Math.floor(Q.nationalism);
Q.socialism_disp = Math.floor(Q.socialism);

var parties = ['spd', 'kpd', 'z', 'ddp', 'dvp', 'dnvp', 'nsdap', 'other', 'lvp', 'kvp', 'dnf'];
var classes = ['workers', 'new_middle', 'old_middle', 'rural', 'unemployed', 'catholics'];

var classSizes = {
    workers: Q.workers,
    new_middle: Q.new_middle,
    old_middle: Q.old_middle,
    rural: Q.rural,
    unemployed: Q.unemployed,
    catholics: Q.catholics
};

var total = 0;

for (var party of parties) {
    var raw = 0;

    for (var c of classes) {
        var classSize = classSizes[c];
        var support = Q[c + '_' + party];

        if (classSize === undefined) {
            console.log('Missing class size:', c);
        }
        if (support === undefined) {
            console.log('Missing support:', c + '_' + party);
        }

        raw += (classSize || 0) * (support || 0);
    }

    Q[party + '_votes_raw'] = raw;
    total += raw;
}

if (total === 0) {
    console.log('WARNING: Vote = 0');
    total = 1;
}

for (var party of parties) {
    Q[party + '_votes'] = +((Q[party + '_votes_raw'] / total) * 100).toFixed(1);
    console.log(party + ': ' + Q[party + '_votes'] + '%');
}

Q.prog_list_disp = Q.kpd_votes + Q.spd_votes + Q.ddp_votes;

if (Q.lvp_formed) {
    Q.lib_list_disp = Q.lvp_votes + (Q.other_votes/2);
}

if (!Q.lvp_formed) {
    Q.lib_list_disp = Q.ddp_votes + Q.dvp_votes + (Q.other_votes/2);
}

Q.harz_list_disp = Q.nsdap_votes + Q.dnf_votes;

if (Q.dnvp_ideology == "Radical") {
    Q.harz_list_disp += Q.dnvp_votes;
}

Q.bou_list_disp = Q.z_votes + Q.ddp_votes + Q.lvp_votes + Q.dvp_votes + Q.kvp_votes;

if (Q.dnvp_ideology == "Moderate") {
    Q.bou_list_disp += Q.dnvp_votes;
}

Q.agr_list_disp = Q.dnvp_votes + Q.others_votes;

Q.agr_soc_list_disp = 0;

if (!Q.lvp_formed) {
    Q.wei_list_disp = (Q.z_votes - 3) + Q.ddp_votes + Q.spd_votes;
}

if (Q.lvp_formed) {
    Q.wei_list_disp = (Q.z_votes - 3) + Q.lvp_votes + Q.spd_votes;
}

Q.lnd_list_disp = Q.lvp_votes + Q.z_votes + Q.dvp_votes + Q.kvp_votes + Q.other_votes;

!}

= Projected election results

(if the election were to be held now):
### Add Splinter parties, with either their vote percent or "Not Formed" if they're'n't formed

<span style="color: #c00000;">**SPD**</span>: [+ spd_votes +]%

