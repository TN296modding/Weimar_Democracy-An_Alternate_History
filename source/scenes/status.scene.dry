Q.iww_nmc_perc_dis = (Q.iww_nmc_perc * 100).toFixed(3);
Q.iww_rur_perc_dis = (Q.iww_rur_perc * 100).toFixed(3);
Q.iww_unm_perc_dis = (Q.iww_unm_perc * 100).toFixed(3);
Q.chrun_tot_perc_dis = (Q.chrun_tot_perc * 100).toFixed(3);
!}

