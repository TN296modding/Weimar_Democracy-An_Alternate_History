@domestic_tab
on-arrival: {!
Q.food_national = (Q.state_buyer/4) + (Q.socializations/2);
!}

= Domestic Affairs

Rural Affairs:

    Land Reform: [+ land_reform : land_reform +]

    Agricultural Financing: [+ agricultural_finance : agri_financing +]

    Food Prices: [+ food_prices : food_prices +]

